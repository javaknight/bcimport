# BigCommerce API
BC_STORE_HASH=your_store_hash
BC_CLIENT_ID=your_client_id
BC_CLIENT_SECRET=your_client_secret
BC_ACCESS_TOKEN=your_access_token
CHANNEL_IDS=1,1837773,1837778,1837790,1837802  # comma-separated; 1=storefront, others=shopping channels
CATEGORY_TREE=1

# BigCommerce WebDAV (for mirrored PDF hosting)
# Example: https://store-abc123.mybigcommerce.com/dav
BC_WEBDAV_URL=
# WebDAV username/password from BC control panel
BC_WEBDAV_USER=
BC_WEBDAV_PASS=
# Public /content base URL used in product descriptions
# Example: https://grandbrass.com/content
BC_CONTENT_BASE_URL=

# AWS
AWS_REGION=us-east-1
S3_SECRETS_BUCKET=your_bucket_name
